# Copy this to .env.local and fill in real values.
# NEVER commit .env.local — it is gitignored.
# NEVER use these placeholder values in production.
#
# Generate secrets:
#   SESSION_SECRET:   openssl rand -base64 32
#   SYNC_SECRET:      openssl rand -base64 32
#   DB password:      openssl rand -base64 32   (use in DATABASE_URL)
#
# Rotate vendor API keys at their respective dashboards:
#   TwelveData: https://twelvedata.com/account/api-keys
#   Finnhub:    https://finnhub.io/dashboard
#   FMP:        https://financialmodelingprep.com/developer/docs/dashboard

# ── Database (Railway or local SSH tunnel) ──────────────────────────────────
DATABASE_URL=mysql://root:<DB_PASSWORD>@localhost:3319/trading

# ── App auth ────────────────────────────────────────────────────────────────
SESSION_SECRET=<GENERATED_AT_DEPLOY_openssl_rand_-base64_32>
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<STRONG_PASSWORD>

# ── Cron sync endpoint secret ────────────────────────────────────────────────
# Required — endpoint returns 401 if this is missing or wrong.
SYNC_SECRET=<GENERATED_AT_DEPLOY_openssl_rand_-base64_32>

# ── Third-party market data APIs ─────────────────────────────────────────────
TWELVEDATA_API_KEY=<ROTATE_AT_TWELVEDATA_DASHBOARD>
FINNHUB_API_KEY=<ROTATE_AT_FINNHUB_DASHBOARD>
FMP_API_KEY=<ROTATE_AT_FMP_DASHBOARD>

# ── OpenAI (voice / research features) ───────────────────────────────────────
OPENAI_API_KEY=<YOUR_OPENAI_KEY>
