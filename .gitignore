# Catch-all for any PNG/JPEG screenshot dropped in the repo root.
# Stable product assets live in /public or /docs — root is agent scratch.
/*.png
/*.jpeg
/*.jpg

# Ephemeral artifacts: backfill reports, ad-hoc probe output, test reports
/backfill-*.json
/yahoo-*.json
/.tmp/
/test-results/
