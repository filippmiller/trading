# Copy this to docker/.env and fill in real values generated with:
#   openssl rand -base64 32
#
# NEVER commit docker/.env — it is gitignored.
# NEVER use these placeholder values in production.

MYSQL_ROOT_PASSWORD=<GENERATED_AT_DEPLOY_openssl_rand_-base64_32>
MYSQL_DATABASE=trading
